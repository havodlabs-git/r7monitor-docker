# ─── Database ─────────────────────────────────────────────────────────────────
# Formato: mysql://user:password@host:3306/database
DATABASE_URL=mysql://r7monitor:changeme@db:3306/r7monitor

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Segredo para assinar os tokens JWT de sessão (mínimo 32 caracteres)
JWT_SECRET=change-this-to-a-random-secret-of-at-least-32-chars

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Origens permitidas para o frontend (separadas por vírgula)
CORS_ORIGINS=http://localhost:80,http://localhost:3001

# ─── Manus OAuth (opcional) ───────────────────────────────────────────────────
# Deixar vazio para desativar a autenticação Manus OAuth
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
APP_ID=
