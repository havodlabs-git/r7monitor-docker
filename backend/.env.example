# ─── Base de Dados ────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://r7monitor:changeme@db:5432/r7monitor

# ─── Autenticação JWT ─────────────────────────────────────────────────────────
# Segredo para assinar os tokens JWT de sessão
# Gerar com: openssl rand -hex 64
JWT_SECRET=change-this-to-a-random-64-char-secret

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Origens permitidas para o frontend (separadas por vírgula)
# Em produção, colocar o domínio real do frontend
CORS_ORIGINS=https://yourdomain.com,http://localhost:5173
