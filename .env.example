# ═══════════════════════════════════════════════════════════════════════════════
# R7 Monitor — Variáveis de Ambiente (raiz)
# Copiar para .env e preencher os valores antes de executar: docker compose up -d
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Base de Dados PostgreSQL ─────────────────────────────────────────────────
# Password do PostgreSQL (utilizador e BD são sempre "r7monitor")
DB_PASSWORD=changeme

# ─── Certificados SSL ─────────────────────────────────────────────────────────
# Caminho no host para a pasta com fullchain.pem e privkey.pem
# Exemplo com Let's Encrypt: /etc/letsencrypt/live/r7monitor.example.com
CERTS_PATH=./certs
