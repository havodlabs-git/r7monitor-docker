# ═══════════════════════════════════════════════════════════════════════════════
# R7 Monitor — Variáveis de Ambiente
# Copiar para .env e preencher os valores antes de executar docker compose up
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Base de dados MySQL ───────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root_password_change_me
MYSQL_DATABASE=r7monitor
MYSQL_USER=r7monitor
MYSQL_PASSWORD=db_password_change_me

# Porta exposta do MySQL no host (opcional, padrão: 3306)
# DB_PORT=3306

# ─── Backend ──────────────────────────────────────────────────────────────────
# Segredo JWT para assinar tokens de sessão (mínimo 32 caracteres aleatórios)
# Gerar com: openssl rand -hex 32
JWT_SECRET=change_this_to_a_random_secret_of_at_least_32_chars

# Porta exposta do backend no host (opcional, padrão: 3000)
# BACKEND_PORT=3000

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Porta exposta do frontend no host (padrão: 80)
# FRONTEND_PORT=80
